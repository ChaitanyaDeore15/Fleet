<%- include('../partials/header') %>
    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="auth-logo">
                <div class="logo-icon">🚛</div>
                <div>
                    <h1>FleetOps</h1><span>Password Recovery</span>
                </div>
            </div>
            <%- include('../partials/flash') %>
                <h2>Forgot Password?</h2>
                <p class="sub">Enter your registered email and we'll send you a reset link valid for 15 minutes.</p>
                <form method="POST" action="/forgot-password">
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" name="email" placeholder="you@company.com" required autofocus />
                    </div>
                    <button type="submit" class="btn btn-primary btn-full">Send Reset Link</button>
                </form>
                <p style="text-align:center;margin-top:18px;font-size:.85rem;color:var(--text-muted);">
                    <a href="/login">← Back to Login</a>
                </p>
        </div>
    </div>
    <script src="/js/main.js"></script>
    </body>

    </html>