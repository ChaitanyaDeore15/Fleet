<%- include('../partials/header') %>
    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="auth-logo">
                <div class="logo-icon">🚛</div>
                <div>
                    <h1>FleetOps</h1><span>Email Verification</span>
                </div>
            </div>
            <%- include('../partials/flash') %>
                <h2>Check your inbox</h2>
                <p class="sub">We sent a 6-digit OTP to <strong>
                        <%= email %>
                    </strong>. Enter it below to verify your email.</p>
                <form method="POST" action="/verify-email">
                    <div class="form-group">
                        <label>OTP Code</label>
                        <input type="text" name="otp" class="otp-input" placeholder="000000" maxlength="6"
                            inputmode="numeric" pattern="\d{6}" required autofocus />
                    </div>
                    <button type="submit" class="btn btn-primary btn-full">Verify Email ✓</button>
                </form>
                <p style="text-align:center;margin-top:12px;font-size:.85rem;color:var(--text-muted);">
                    Didn't get the code? <a href="/resend-otp">Resend OTP</a>
                </p>
                <p style="text-align:center;margin-top:18px;font-size:.85rem;color:var(--text-muted);">
                    Wrong email? <a href="/signup">Go back</a>
                </p>
        </div>
    </div>
    <script src="/js/main.js"></script>
    </body>

    </html>