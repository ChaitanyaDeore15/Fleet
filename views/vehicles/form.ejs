<%- include('../partials/header') %>
    <div class="app-wrapper">
        <%- include('../partials/sidebar') %>
            <div class="main-content">
                <%- include('../partials/topbar') %>
                    <div class="page-body">
                        <%- include('../partials/flash') %>
                            <div class="page-header">
                                <div>
                                    <h1>
                                        <%= vehicle ? '✏️ Edit Vehicle' : '+ Add Vehicle' %>
                                    </h1>
                                    <p><a href="/vehicles">← Back to Vehicle Registry</a></p>
                                </div>
                            </div>
                            <div class="card" style="max-width:540px;">
                                <div class="card-body">
                                    <form method="POST"
                                        action="<%= vehicle ? '/vehicles/edit/' + vehicle.id : '/vehicles/add' %>">
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>License Plate</label>
                                                <input type="text" name="license_plate"
                                                    value="<%= vehicle ? vehicle.license_plate : '' %>"
                                                    placeholder="MH-12-AA-1234" required />
                                            </div>
                                            <div class="form-group">
                                                <label>Model</label>
                                                <input type="text" name="model"
                                                    value="<%= vehicle ? vehicle.model : '' %>" placeholder="Tata Ace"
                                                    required />
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Type</label>
                                                <select name="type" required>
                                                    <option value="">Select type</option>
                                                    <% ['Truck','Van', 'Pickup' , 'Tanker' , 'Trailer' , 'Mini Truck'
                                                        ].forEach(t=> { %>
                                                        <option value="<%= t %>" <%=vehicle && vehicle.type===t
                                                            ? 'selected' : '' %>>
                                                            <%= t %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label>Max Capacity (tonnes)</label>
                                                <input type="number" name="max_capacity" step="0.1" min="0.1"
                                                    value="<%= vehicle ? vehicle.max_capacity : '' %>" placeholder="5.0"
                                                    required />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label>Odometer Reading (km)</label>
                                            <input type="number" name="odometer" step="0.1" min="0"
                                                value="<%= vehicle ? vehicle.odometer : '0' %>" placeholder="0" />
                                        </div>
                                        <div style="display:flex;gap:10px;margin-top:8px;">
                                            <button type="submit" class="btn btn-primary">
                                                <%= vehicle ? 'Update Vehicle' : 'Add Vehicle' %>
                                            </button>
                                            <a href="/vehicles" class="btn btn-outline">Cancel</a>
                                        </div>
                                    </form>
                                </div>
                            </div>
                    </div>
            </div>
    </div>
    <script src="/js/main.js"></script>
    </body>

    </html>