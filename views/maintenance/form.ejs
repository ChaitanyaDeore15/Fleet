<%- include('../partials/header') %>
    <div class="app-wrapper">
        <%- include('../partials/sidebar') %>
            <div class="main-content">
                <%- include('../partials/topbar') %>
                    <div class="page-body">
                        <%- include('../partials/flash') %>
                            <div class="page-header">
                                <div>
                                    <h1>+ Log Maintenance</h1>
                                    <p><a href="/maintenance">← Back to Maintenance</a></p>
                                </div>
                            </div>
                            <div class="card" style="max-width:560px;">
                                <div class="card-body">
                                    <form method="POST" action="/maintenance/add" enctype="multipart/form-data">
                                        <div class="form-group">
                                            <label>Vehicle</label>
                                            <select name="vehicle_id" required>
                                                <option value="">Select vehicle</option>
                                                <% vehicles.forEach(v=> { %>
                                                    <option value="<%= v.id %>">
                                                        <%= v.license_plate %> — <%= v.model %> (<%=
                                                                    v.status.replace('_',' ') %>)</option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>Issue Description</label>
              <textarea name="issue" rows="3" placeholder="Describe the issue..." required></textarea>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Estimated Cost (₹)</label>
                <input type="number" name="cost" min="0" step="0.01" placeholder="0.00" />
              </div>
              <div class="form-group">
                <label>Service Date</label>
                <input type="date" name="service_date" value="<%= new Date().toISOString().split(' T')[0] %>" required
                                                                    />
                                        </div>
                                </div>
                                <div class="form-group">
                                    <label>Receipt / Invoice (optional)</label>
                                    <div class="file-input-wrapper">
                                        <input type="file" name="receipt" accept=".jpg,.jpeg,.png,.pdf" />
                                        <span class="file-name"
                                            style="font-size:.8rem;color:var(--text-muted);margin-top:4px;display:block;">No
                                            file chosen</span>
                                    </div>
                                </div>
                                <div class="alert alert-warning">⚠️ Logging maintenance will automatically set the
                                    selected vehicle's status to <strong>In Shop</strong>.</div>
                                <div style="display:flex;gap:10px;">
                                    <button type="submit" class="btn btn-primary">Log Issue</button>
                                    <a href="/maintenance" class="btn btn-outline">Cancel</a>
                                </div>
                                </form>
                            </div>
                    </div>
            </div>
    </div>
    </div>
    <script src="/js/main.js"></script>
    </body>

    </html>