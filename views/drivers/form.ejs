<%- include('../partials/header') %>
    <div class="app-wrapper">
        <%- include('../partials/sidebar') %>
            <div class="main-content">
                <%- include('../partials/topbar') %>
                    <div class="page-body">
                        <%- include('../partials/flash') %>
                            <div class="page-header">
                                <div>
                                    <h1>
                                        <%= driver ? '✏️ Edit Driver' : '+ Add Driver' %>
                                    </h1>
                                    <p><a href="/drivers">← Back to Drivers</a></p>
                                </div>
                            </div>
                            <div class="card" style="max-width:580px;">
                                <div class="card-body">
                                    <form method="POST"
                                        action="<%= driver ? '/drivers/edit/' + driver.id : '/drivers/add' %>"
                                        enctype="multipart/form-data">
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Full Name</label>
                                                <input type="text" name="name" value="<%= driver ? driver.name : '' %>"
                                                    placeholder="Driver name" required />
                                            </div>
                                            <div class="form-group">
                                                <label>License Number</label>
                                                <input type="text" name="license_number"
                                                    value="<%= driver ? driver.license_number : '' %>"
                                                    placeholder="MH0120210012345" required />
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>License Expiry</label>
                                                <input type="date" name="license_expiry"
                                                    value="<%= driver ? new Date(driver.license_expiry).toISOString().split('T')[0] : '' %>"
                                                    required />
                                            </div>
                                            <div class="form-group">
                                                <label>Safety Score (0-100)</label>
                                                <input type="number" name="safety_score" min="0" max="100"
                                                    value="<%= driver ? driver.safety_score : '100' %>" />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label>Driver Document (License / ID)</label>
                                            <div class="file-input-wrapper">
                                                <input type="file" name="driver_doc"
                                                    accept=".jpg,.jpeg,.png,.pdf,.doc,.docx" />
                                                <span class="file-name"
                                                    style="font-size:.8rem;color:var(--text-muted);margin-top:4px;display:block;">
                                                    <%= driver && driver.document_path ? 'Current: ' +
                                                        driver.document_path.split(/[\\/]/).pop() : 'No file chosen' %>
                                                </span>
                                            </div>
                                        </div>
                                        <div style="display:flex;gap:10px;margin-top:8px;">
                                            <button type="submit" class="btn btn-primary">
                                                <%= driver ? 'Update Driver' : 'Add Driver' %>
                                            </button>
                                            <a href="/drivers" class="btn btn-outline">Cancel</a>
                                        </div>
                                    </form>
                                </div>
                            </div>
                    </div>
            </div>
    </div>
    <script src="/js/main.js"></script>
    </body>

    </html>